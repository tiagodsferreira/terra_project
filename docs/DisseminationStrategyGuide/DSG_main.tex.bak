\documentclass[11pt,a4paper]{article}

\usepackage{fontspec}
\usepackage[a4paper,margin=2.5cm]{geometry}
\usepackage{hyperref}
\usepackage{xurl}
\usepackage{enumitem}
\usepackage{parskip}
\usepackage{amssymb}
\usepackage{array}
\usepackage{ragged2e}
\usepackage{caption}
\usepackage{graphicx}
\usepackage{fancyhdr}
\usepackage{lastpage}

\newcolumntype{P}[1]{>{\raggedright\arraybackslash}p{#1}}

\graphicspath{{images/}}

\hypersetup{
  colorlinks=true,
  linkcolor=blue,
  urlcolor=blue
}

% ---- Global page geometry for header/footer ----
\setlength{\headheight}{50pt}
\setlength{\headsep}{15pt}
\setlength{\footskip}{35pt}

\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% =========================
% TITLE PAGE (with funders)
% =========================
\fancypagestyle{title}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}

  \fancyhead[L]{\includegraphics[height=1.6cm]{terra_white.png}}
  \fancyhead[R]{%
    \includegraphics[height=1.4cm]{fpceup.jpg}\hspace{0.5cm}%
    \includegraphics[height=1.4cm]{CPUP_EN.jpg}%
  }

  \fancyfoot[L]{%
    \includegraphics[height=1.1cm]{FCT_preto.jpg}\hspace{0.6cm}%
    \includegraphics[height=1.1cm]{funding_bar_white.png}%
  }
  \fancyfoot[R]{\thepage\ of \pageref{LastPage}}
}

% =========================
% BODY PAGES
% =========================
\fancypagestyle{body}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}

  \fancyhead[C]{%
    \includegraphics[height=1.4cm]{terra_white_long.png}%
  }
  \fancyfoot[R]{\thepage\ of \pageref{LastPage}}
}

\begin{document}

% ---- Title page ----
\thispagestyle{title}
\input{DSG_titlepage}
\clearpage

% ---- Body pages ----
\pagestyle{body}
\input{DSG_body}

\end{document}
